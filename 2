#include <stdio.h>

void add(int a[10][10], int b[10][10], int r, int c) {
    int i, j, sum[10][10];
    for(i=0;i<r;i++) {
        for(j=0;j<c;j++) {
            sum[i][j] = a[i][j] + b[i][j];
            printf("%d ", sum[i][j]);
        }
        printf("\n");
    }
}

void multiply(int a[10][10], int b[10][10], int r1, int c1, int c2) {
    int i,j,k, mul[10][10]={0};

    for(i=0;i<r1;i++) {
        for(j=0;j<c2;j++) {
            for(k=0;k<c1;k++) {
                mul[i][j] += a[i][k] * b[k][j];
            }
            printf("%d ", mul[i][j]);
        }
        printf("\n");
    }
}

void transpose(int a[10][10], int r, int c) {
    int i,j;
    for(i=0;i<c;i++) {
        for(j=0;j<r;j++) {
            printf("%d ", a[j][i]);
        }
        printf("\n");
    }
}

int main() {
    int a[10][10], b[10][10], r, c, i, j;

    printf("Enter rows and columns: ");
    scanf("%d %d", &r, &c);

    printf("Enter Matrix A:\n");
    for(i=0;i<r;i++)
        for(j=0;j<c;j++)
            scanf("%d", &a[i][j]);

    printf("Enter Matrix B:\n");
    for(i=0;i<r;i++)
        for(j=0;j<c;j++)
            scanf("%d", &b[i][j]);

    printf("\nAddition:\n");
    add(a,b,r,c);

    printf("\nMultiplication:\n");
    multiply(a,b,r,c,c);

    printf("\nTranspose of Matrix A:\n");
    transpose(a,r,c);

    return 0;
}
