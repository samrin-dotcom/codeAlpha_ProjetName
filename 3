#include <stdio.h>
#include <stdlib.h>

struct student {
    int id;
    char name[50];
    float marks;
};

void add() {
    struct student s;
    FILE *fp = fopen("students.txt", "a");

    printf("Enter ID, Name, Marks: ");
    scanf("%d %s %f", &s.id, s.name, &s.marks);

    fwrite(&s, sizeof(s), 1, fp);
    fclose(fp);
}

void display() {
    struct student s;
    FILE *fp = fopen("students.txt", "r");

    while(fread(&s, sizeof(s), 1, fp)) {
        printf("%d %s %.2f\n", s.id, s.name, s.marks);
    }
    fclose(fp);
}

int main() {
    int ch;

    do {
        printf("\n1.Add\n2.Display\n3.Exit\nEnter choice: ");
        scanf("%d", &ch);

        switch(ch) {
            case 1: add(); break;
            case 2: display(); break;
        }
    } while(ch != 3);

    return 0;
}
